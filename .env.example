# App
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ENCRYPTION_KEY=change-me-use-fernet-generate-key

# Admin auto-creation on startup
ADMIN_EMAIL=admin@tokenrelay.com
ADMIN_PASSWORD=admin123456

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Redis (leave empty for in-memory fallback)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_PER_USER_PER_MINUTE=60
RATE_LIMIT_GLOBAL_PER_MINUTE=10000

# CORS
CORS_ORIGINS=["*"]

# Registration (set to false to whitelist-only)
REGISTRATION_OPEN=true
